---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getAllTags, getPostPath, getSortedPosts } from "../../utils/posts";

export async function getStaticPaths() {
  const tags = await getAllTags();

  return tags.map((tag) => ({
    params: { tag: tag.toLowerCase() },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const posts = (await getSortedPosts()).filter((post) => post.data.tags.includes(tag));
---

<BaseLayout
  title={`${tag} 标签`}
  description={`Time Vapour Blog 中关于 ${tag} 的文章。`}
  bodyClass="tag-page"
>
  <main class="content-section archive-layout">
    <div class="section-heading">
      <p class="kicker">Tag</p>
      <h1>{tag}</h1>
    </div>

    <div class="post-list">
      {posts.map((post) => (
        <article class="post-card">
          <a href={getPostPath(post.id)}>
            <time class="post-date" datetime={formatDate(post.data.date)}>
              {formatDate(post.data.date)}
            </time>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
