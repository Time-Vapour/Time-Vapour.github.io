---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../site";
import { formatDate, getPostPath, getSortedPosts, getTagPath } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const posts = await getSortedPosts();
const postIndex = posts.findIndex((entry) => entry.id === post.id);
const newerPost = postIndex > 0 ? posts[postIndex - 1] : undefined;
const olderPost = postIndex < posts.length - 1 ? posts[postIndex + 1] : undefined;
const publishedAt = formatDate(post.data.date);
const updatedAt = formatDate(post.data.updated ?? post.data.date);
const canonicalUrl = new URL(getPostPath(post.id), Astro.site).toString();
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedAt,
  dateModified: updatedAt,
  author: {
    "@type": "Person",
    name: post.data.author
  },
  image: [new URL(post.data.cover, Astro.site).toString()],
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  keywords: post.data.tags
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  bodyClass="post-page"
  type="article"
  image={post.data.cover}
  jsonLd={articleJsonLd}
  author={post.data.author}
  publishedAt={post.data.date.toISOString()}
  updatedAt={(post.data.updated ?? post.data.date).toISOString()}
  readingProgress
>
  <main class="post-layout">
    <article class="post-article">
      <header class="post-hero">
        <a class="back-link" href="/">返回首页</a>
        <time class="post-date" datetime={publishedAt}>{publishedAt}</time>
        {updatedAt !== publishedAt && <time class="post-date updated-date" datetime={updatedAt}>Updated {updatedAt}</time>}
        <h1>{post.data.title}</h1>
        <p class="post-author">By {post.data.author}</p>
        {post.data.tags.length > 0 && (
          <div class="tag-list" aria-label="文章标签">
            {post.data.tags.map((tag) => <a href={getTagPath(tag)}>{tag}</a>)}
          </div>
        )}
      </header>
      <div class="markdown-body">
        <Content />
      </div>
      <aside class="post-copyright" aria-label="版权保护">
        <p class="kicker">Copyright</p>
        <p>{site.copyright}</p>
      </aside>
      <nav class="post-nav" aria-label="文章导航">
        {newerPost ? (
          <a href={getPostPath(newerPost.id)}>
            <span>上一篇</span>
            <strong>{newerPost.data.title}</strong>
          </a>
        ) : <span></span>}
        {olderPost ? (
          <a href={getPostPath(olderPost.id)}>
            <span>下一篇</span>
            <strong>{olderPost.data.title}</strong>
          </a>
        ) : <span></span>}
      </nav>
    </article>
  </main>
</BaseLayout>
